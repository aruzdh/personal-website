---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formattedDate = entry.data.date.toISOString().split('T')[0];
---

<MainLayout title={entry.data.title} subtitle={entry.data.subtitle}>
  <article class="post-container">
    
    <header class="post-meta">
      <span class="text-orange">[{formattedDate}]</span>
      <span class="dim-text"># {entry.data.tag.toLowerCase()}</span>
    </header>

    <div class="markdown-body">
      <Content />
    </div>

    <div class="post-footer">
      <a href="/life" class="cmd-link">{"=> "} RETURN_TO_LIFE_LOGS</a>
    </div>

  </article>
</MainLayout>

<style>
  .post-container {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.85rem;
    line-height: 1.6;
    max-width: 650px;
    margin: 0 auto;
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    font-weight: bold;
    margin-bottom: 2rem;
    border-bottom: 1px dashed var(--bg-alt);
    padding-bottom: 0.5rem;
  }

  .dim-text { color: var(--fg-light); }
  .text-orange { color: var(--orange, #ff5f00); }

  .markdown-body :global(h2),
  .markdown-body :global(h3) {
    color: var(--fg);
    font-weight: bold;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .markdown-body :global(h2) { font-size: 1.1rem; }
  .markdown-body :global(h3) { font-size: 0.95rem; }

  .markdown-body :global(p) {
    margin-bottom: 1.25rem;
    color: var(--fg);
  }

  .markdown-body :global(pre) {
    background: var(--bg-alt) !important;
    border-left: 2px solid var(--blue);
    padding: 1rem;
    margin: 1.5rem 0;
    overflow-x: auto;
  }

  .markdown-body :global(code) {
    font-family: var(--font-mono, monospace);
    font-size: 0.8rem;
  }

  .post-footer {
    margin-top: 3rem;
    border-top: 1px dashed var(--bg-alt);
    padding-top: 1.5rem;
    text-align: center;
  }

  .cmd-link {
    display: inline-block;
    color: var(--blue);
    text-decoration: none;
    font-weight: bold;
    padding: 0.2rem 0.5rem;
  }

  .cmd-link:hover {
    background-color: var(--blue);
    color: var(--bg);
  }
</style>
