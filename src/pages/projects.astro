---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';

const allProjects = await getCollection('projects');

const getFileMeta = (status: string, keywords: string[], scope: string) => {
  const isDir = status === 'active' || status === 'complete';
  return {
    permissions: isDir ? 'drwxr-xr-x' : '-rw-r--r--',
    typeIndicator: isDir ? '/' : '',
    language: keywords[0] ? keywords[0].toLowerCase() : 'raw',
    scope: scope,
    status: status
  };
};
---

<MainLayout title="These are my current side projects :)" subtitle="The future ones will be about Formal Verification (using Rocq; i love Rocq)">
  <section class="terminal-filesystem">
    <p class="shell-prompt">total {allProjects.length} side-projects</p>

    <div class="fs-header fs-row">
      <span class="col-perm">PERMISSIONS</span>
      <span class="col-lang">LANGUAGE</span>
      <span class="col-size">SCOPE</span>
      <span class="col-date">STATUS</span>
      <span class="col-name">NAME</span>
    </div>

    <div class="fs-entries">
      {allProjects.map((project) => {
      const meta = getFileMeta(project.data.status, project.data.keywords, project.data.scope);

        return (
          <details class="project-details">
            <summary class="fs-row entry-summary">
              <span class="col-perm dim-text">{meta.permissions}</span>
              <span class="col-lang text-blue">[{meta.language}]</span>
              <span class="col-size dim-text">{meta.scope}</span>
              <span class="col-date dim-text">{meta.status}</span>
              <span class="col-name font-bold">
                {project.data.name.toLowerCase().replace(/\s+/g, '_')}{meta.typeIndicator}
              </span>
            </summary>

            <div class="file-content">
              <p class="cat-command">
                <span class="prompt-arrow">└─$</span> cat {project.data.name.toLowerCase().replace(/\s+/g, '_')}/README.md
              </p>

              <div class="readme-body">
                <p><span class="meta-label">DESCRIPTION:</span> {project.data.description}</p>
                <p><span class="meta-label">STATUS:</span> [{project.data.status.toUpperCase()}]</p>
                <p><span class="meta-label">KEYWORDS:</span> {project.data.keywords.join(', ')}</p>

                <div class="readme-links">
                  <a href={project.data.github} target="_blank" rel="noreferrer">
                    [SOURCE_CODE]
                  </a>
                  {project.data.demo && (
                    <a href={project.data.demo} target="_blank" rel="noreferrer">
                      [LIVE_DEMO]
                    </a>
                  )}
                </div>
              </div>
            </div>
          </details>
        );
      })}
    </div>
  </section>
</MainLayout>

<style>
  .terminal-filesystem {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    line-height: 1.5;
  }

  .shell-prompt {
    color: var(--fg-light);
    margin-bottom: 1.5rem;
  }

  .fs-row {
    display: grid;
    grid-template-columns: 110px 100px 125px 110px 1fr;
    gap: 1rem;
    align-items: center;
    padding: 0.35rem 0.5rem;
  }

  .fs-header {
    color: var(--fg-light);
    border-bottom: 1px dashed var(--bg-alt);
    font-weight: bold;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    padding-bottom: 0.5rem;
  }

  .dim-text { color: var(--fg-light); }
  .text-blue { color: var(--blue, #00ffff); }
  .font-bold { font-weight: bold; }

  .project-details {
    border-bottom: 1px solid transparent;
  }

  .entry-summary {
    list-style: none;
    cursor: pointer;
    user-select: none;
  }

  .entry-summary::-webkit-details-marker {
    display: none;
  }

  .entry-summary:hover,
  .project-details[open] .entry-summary {
    background-color: var(--fg, #ffffff);
    color: var(--bg, #000000);
  }
  
  .entry-summary:hover .dim-text,
  .entry-summary:hover .text-blue,
  .project-details[open] .entry-summary .dim-text,
  .project-details[open] .entry-summary .text-blue {
    color: inherit;
  }

  .file-content {
    background: var(--bg-alt);
    border-left: 2px solid var(--border);
    margin: 0.5rem 0 1rem 2rem;
    padding: 1rem;
  }

  .cat-command {
    color: var(--fg-light);
    font-weight: bold;
    margin-bottom: 0.75rem;
  }

  .prompt-arrow {
    color: var(--blue, #00ffff);
  }

  .readme-body {
    padding-left: 1.5rem;
  }

  .readme-body p {
    margin: 0.25rem 0;
  }

  .meta-label {
    color: var(--fg-light);
    display: inline-block;
    width: 110px;
  }

  .readme-links {
    margin-top: 1rem;
    display: flex;
    gap: 1.5rem;
  }

  .readme-links a {
    color: var(--blue, #00ffff);
    text-decoration: none;
    font-weight: bold;
  }

  .readme-links a:hover {
    background-color: var(--blue, #00ffff);
    color: var(--bg, #000000);
  }

  @media (max-width: 768px) {
    .fs-header {
      display: none;
    }
    
    .fs-row {
      grid-template-columns: 90px 1fr; 
    }

    .col-perm, .col-size, .col-date {
      display: none;
    }

    .file-content {
      margin-left: 0.5rem;
      padding: 0.75rem;
    }
    
    .meta-label {
      display: block;
      margin-bottom: 0.1rem;
    }
  }
</style>
