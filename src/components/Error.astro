---
interface Props {
  errorTitle: string;
  progress?: number;
}

const { errorTitle, progress } = Astro.props;
---

<section class="error-container">
  <p class="error-line">
    {">> "} {errorTitle}
  </p>

  {/* The slot element lets you inject custom paragraph text for each unique page */}
  <div class="error-description">
    <slot />
  </div>

  {progress !== undefined && (
    <p class="status-line">
      [ PROGRESS: { "█".repeat(Math.floor(progress / 10)).padEnd(10, "░") } {progress}% ]
    </p>
  )}

  <div class="footer">
    <a href="/" class="cmd-link">{"=> "} RETURN_TO_HOME</a>
  </div>
</section>

<style>
  .error-line {
    color: black; // TODO: var(--error-red, #ff0000);
    font-weight: bold;
    margin-bottom: 1rem;
  }

  .error-description {
    line-height: 1.6;
  }

  .status-line {
    font-size: 0.75rem;
    color: var(--fg-light);
    margin-top: 1rem;
    font-family: var(--font-mono, monospace);
  }

  .footer {
    margin-top: 2rem;
    border-top: 1px dashed var(--bg-alt);
    padding-top: 1.5rem;
    text-align: center;
  }

  .cmd-link {
    color: var(--blue);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: bold;
    padding: 0.2rem 0.5rem;
  }

  .cmd-link:hover,
  .cmd-link:focus-visible {
    background-color: var(--blue);
    color: var(--bg);
  }
</style>
